{
  "manifest_version": 3,
  "name": "FocusUnlock",
  "description": "Unlock distraction sites by earning focused work time.",
  "version": "1.0.0",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "idle"
  ],
  "host_permissions": [
    "*://*/*",
    "https://focusunlock.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "FocusUnlock"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "*://*/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
